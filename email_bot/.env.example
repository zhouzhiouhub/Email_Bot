# ============================================================================
# Email Auto-Processing Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================================

# === Brand / Identity ===
# These define the AI persona and are used in generated replies.
BRAND_NAME=MyBrand
SUPPORT_AGENT_NAME=Alex
COMPANY_DESCRIPTION=a software company providing technical support
SUPPORT_EMAIL_SIGNATURE=Technical Support Team\nsupport@example.com

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/email_bot
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/email_bot

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === Email (IMAP/SMTP) ===
# Multi-account JSON array format:
# EMAIL_ACCOUNTS=[{"address":"support@example.com","password":"your-app-password","imap_host":"imap.gmail.com","imap_port":993,"smtp_host":"smtp.gmail.com","smtp_port":587,"from_name":"Support"}]
EMAIL_ACCOUNTS=[]

# IMAP polling interval (seconds)
IMAP_POLL_INTERVAL_SECONDS=60

# IMAP IDLE (push-based, near-zero latency)
IMAP_IDLE_ENABLED=false
IMAP_IDLE_RENEW_SECONDS=1500

# === OpenAI / LLM ===
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Webhook Notification (for human review alerts) ===
# Supports DingTalk, Slack, Feishu, or any generic webhook
NOTIFICATION_PLATFORM=dingtalk
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# === Service ===
# Base URL of this service (used to generate review links in notifications)
SERVICE_BASE_URL=http://localhost:8000

# === Confidence Thresholds ===
# Replies above this threshold are auto-sent
CONFIDENCE_AUTO_REPLY=0.85
# Replies below this threshold go to human review
CONFIDENCE_HUMAN_REVIEW=0.60

# === FAQ Scraper ===
# URL to your product's FAQ page (leave empty to disable)
FAQ_URL=

# === Type B Sender Detection ===
# Comma-separated list of system sender email addresses (contact form forwarding)
TYPE_B_SENDER_ADDRESSES=

# === Application ===
APP_ENV=development
LOG_LEVEL=INFO
